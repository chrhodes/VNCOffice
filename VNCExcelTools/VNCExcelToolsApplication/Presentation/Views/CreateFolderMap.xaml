    <!-- Simple Layout using Grid -->

    <DockPanel Margin="5">

        <vncviews:DeveloperUIInfo x:Name="spDeveloperInfo" DockPanel.Dock="Bottom"/>

        <dxlc:LayoutControl x:Name="layoutItems" Orientation="Vertical" Background="#FFFFFF">
            
            <dxlc:LayoutGroup Header="Folder Selection"
                View="GroupBox" Orientation="Horizontal" VerticalAlignment="Top"
                IsCollapsible="True"  IsCollapsed="False">
                
                <dxlc:LayoutItem Label="StartingFolder" LabelPosition="Top" VerticalAlignment="Stretch"  >
                <!-- Hopefully we don't use the first one anymore! 
                    <dxe:TextEdit x:Name="teStartingFolder"
                		Text="{Binding StartingFolder}"
                    	ToolTip="tooltip"
                     	MouseDoubleClick="teStartingFolder_MouseDoubleClick" />
                -->
                    <dxe:TextEdit
                		Text="{Binding StartingFolder }"
                    	ToolTip="{Binding StartingFolderToolTip }">
                        <!--<i1:Interaction.Triggers>
                            <i1:EventTrigger EventName="MouseDoubleClick">
                                <prism:InvokeCommandAction Command="{Binding Path=StartingFolder_DoubleClick_Command}"/>
                             </i1:EventTrigger>
                        </i1:Interaction.Triggers>-->
                    </dxe:TextEdit>
                </dxlc:LayoutItem>
                
                <!-- Second form uses CommandParameter -->
                <dxlc:LayoutItem  VerticalAlignment="Stretch" HorizontalAlignment="Right">
                    <Button Width="100"
                        Command="{Binding PickStartingFolderCommand }"

                		ToolTip="{Binding PickStartingFolderToolTip, FallbackValue='PickStartingFolder ToolTip' }">
                        <TextBlock 
                            TextWrapping="Wrap" TextAlignment="Center"
                            Text="{Binding PickStartingFolderContent, FallbackValue='Pick Starting Folder' }">

                        </TextBlock>
                    </Button>
                </dxlc:LayoutItem>
                <!-- <dxlc:LayoutItem> -->
                    <!-- <Button -->
                        <!-- Command="{Binding PickStartingFolderCommand}" -->
                        <!-- CommandParameter="{Binding PickStartingFolderCommandParameter}" -->
                        <!-- Content="{Binding PickStartingFolderContent, FallbackValue='PickStartingFolder' }" -->
