                        <!-- </Button.Background> -->
                <!-- </dxlc:LayoutItem> -->          
                
            </dxlc:LayoutGroup>

            <dxlc:LayoutGroup Header="Folder Map Content"
                View="GroupBox" Orientation="Vertical" 
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                IsCollapsible="True"  IsCollapsed="False">

                <dxlc:LayoutGroup View="Group" Orientation="Horizontal" >
                    <!--<dxlc:LayoutItem Label="Show Folders" >-->
                    <dxe:CheckEdit x:Name="ceShowFolders" 
                                Content="Show Folders"
                                HorizontalAlignment="Left"
                    	        IsChecked="{Binding ShowFolders}"/>
                    <!--</dxlc:LayoutItem>-->

                    <!--<dxlc:LayoutItem Label="Skip Empty Folders">-->
                    <dxe:CheckEdit x:Name="ceSkipEmptyFolders" 
                                Content="Skip Empty Folders"
                                HorizontalAlignment="Left"
                    	        IsChecked="{Binding SkipEmptyFolders}"/>
                    <!--</dxlc:LayoutItem>-->

                    <dxlc:LayoutGroup View="Group" Orientation="Horizontal" HorizontalAlignment="Right" >
                        <dxe:CheckEdit x:Name="ceLimitLevels" 
                                    Content="Limit Levels"                                   
                   	                IsChecked="{Binding LimitLevels}"/>
                        <!--<dxlc:LayoutItem Label="LimitLevels">
                        	<dxe:SpinEdit x:Name="seLimitLevels" 
                        		Value="1" />
                        </dxlc:LayoutItem> -->
                        <!--<dxlc:LayoutItem Label="Limit Levels">-->
                        	<dxe:SpinEdit x:Name="seFolderLimitLevels" 
                        		Value="{Binding FolderLimitLevels, Mode=TwoWay}" />
                        <!--</dxlc:LayoutItem>-->
                        <!--<dxlc:LayoutItem Label="LimitLevels">
                            <dxe:SpinEdit 
                                Value="{Binding LimitLevels, Mode=TwoWay}" 
                                Increment=".005"    
                                MinValue="{Binding MinVoltageChangeTrigger, Mode=OneWay}" 
                                MaxValue="{Binding MaxVoltageChangeTrigger, Mode=OneWay}" 
                                Mask="F3" MaskType="Numeric" MaskUseAsDisplayFormat="True"
                                IsFloatValue="True" 
                                ToolTip="Change Trigger in Volts"/>
                        </dxlc:LayoutItem> -->

                    </dxlc:LayoutGroup>
                    
                </dxlc:LayoutGroup>
               
                <!--<dxlc:LayoutItem Label="Show Files">-->
                <dxe:CheckEdit x:Name="ceShowFiles" 
                            Content="Show Files"
                    	    IsChecked="{Binding ShowFiles}"/>
                <!--</dxlc:LayoutItem>-->

                <dxlc:LayoutGroup x:Name="lgInclusionMatchingRules" Header="Inclusion Matching Rules"
                    View="GroupBox" Orientation="Horizontal" 
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    IsCollapsible="True"  IsCollapsed="False">

                    <dxlc:LayoutGroup Orientation="Vertical">

                        <dxlc:LayoutItem HorizontalAlignment="Left">
                            <dxe:CheckEdit x:Name="ceFolderMatchUsingRegEx"
                                Content="Folder Match Using RegEx" 
                                IsChecked="{Binding FolderMatchUsingRegEx}"/>
                        </dxlc:LayoutItem>

                        <dxlc:LayoutItem Label="Folder Highlight Color" 
                                     IsEnabled="{Binding IsEnabled, ElementName=ceFolderMapRegEx}">
                            <dxe:PopupColorEdit HorizontalAlignment="Left"
                                        IsEnabled="{Binding IsEnabled, ElementName=ceFolderMapRegEx}"
                                        Color="{Binding FolderHighlightColor, Mode=TwoWay}" 
                                        DisplayMode="Color">
                            </dxe:PopupColorEdit>
                        </dxlc:LayoutItem>

                        <!--<dxlc:LayoutItem Label="Folder RexEx Pattern" LabelPosition="Top"
                                     IsEnabled="{Binding IsEnabled, ElementName=ceFolderMapRegEx}">
                            <dxe:TextEdit x:Name="teRegExFolderHilightMatch" 
                                  ToolTip="Illegal Folder Characters Tooltip." />
                        </dxlc:LayoutItem>-->

                        <dxlc:LayoutItem Label="FolderRegExPattern" LabelPosition="Top"
                                         IsEnabled="{Binding IsEnabled, ElementName=ceFolderMapRegEx}">

                            <dxe:TextEdit
                        		Text="{Binding FolderRegExPattern }"
                            	ToolTip="{Binding FolderRegExPatternToolTip }">
                                <!--<i1:Interaction.Triggers>
                                    <i1:EventTrigger EventName="MouseDoubleClick">
                                        <prism:InvokeCommandAction Command="{Binding Path=FolderRegExPattern_DoubleClick_Command}"/>
                                    </i1:EventTrigger>
                                </i1:Interaction.Triggers>-->
                            </dxe:TextEdit>
                        </dxlc:LayoutItem>

                    </dxlc:LayoutGroup>

                    <dxlc:LayoutGroup Orientation="Vertical">

                        <dxlc:LayoutItem HorizontalAlignment="Left">
                            <dxe:CheckEdit x:Name="ceFileMatchUsingRegEx"
                            Content="File Match Using RegEx" 
                            IsChecked="{Binding FileMatchUsingRegEx}"/>
                        </dxlc:LayoutItem>

                        <dxlc:LayoutItem Label="File Highlight Color"
                                      Visibility="{Binding IsEnabled, ElementName=ceFileMatchUsingRegEx}">
                            <dxe:PopupColorEdit HorizontalAlignment="Left"
                                IsEnabled="{Binding IsEnabled, ElementName=ceFileMatchUsingRegEx}"
                                Color="{Binding FileHighlightColor, Mode=TwoWay}" 
                                DisplayMode="Color">
                            </dxe:PopupColorEdit>
                        </dxlc:LayoutItem>

                        <dxlc:LayoutItem Label="File RexEx Pattern" LabelPosition="Top"
                                     IsEnabled="{Binding IsEnabled, ElementName=ceFileMatchUsingRegEx}">
                            <dxe:TextEdit
                        		Text="{Binding FileRegExPattern }"
                            	ToolTip="{Binding FileRegExPatternToolTip }">
                            </dxe:TextEdit>

                        </dxlc:LayoutItem>

                    </dxlc:LayoutGroup>

                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>

            <!--<dxlc:LayoutGroup Header="Inclusion Matching Rules"
