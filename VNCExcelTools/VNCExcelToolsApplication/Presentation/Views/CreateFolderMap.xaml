                    </dxlc:LayoutItem>

                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>-->

            <dxlc:LayoutGroup Header="Date Information"
                View="GroupBox" Orientation="Horizontal" 
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                IsCollapsible="True"  IsCollapsed="False">

                <dxlc:LayoutGroup View="Group" Orientation="Vertical" >
                    <dxlc:LayoutItem HorizontalAlignment="Left">
                        <dxe:CheckEdit x:Name="ceColorCodeDates"
                            Content="Color Code Dates" 
                            IsChecked="False"/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Months Since Created">
                        <dxe:SpinEdit x:Name="seMonthsSinceCreated" HorizontalAlignment="Left"
                                      IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                        		      Value="{Binding MonthsSincedCreated, Mode=TwoWay}" />
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Months Since Written">
                        <dxe:SpinEdit x:Name="seMonthsSinceWritten" HorizontalAlignment="Left"
                                      IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                        		      Value="{Binding MonthsSinceWritten, Mode=TwoWay}" />
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Months Since Accessed">
                        <dxe:SpinEdit x:Name="seMonthsSinceAccessed" HorizontalAlignment="Left"
                                      IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                        		      Value="{Binding MonthsSinceAccessed, Mode=TwoWay}" />
                    </dxlc:LayoutItem>
                </dxlc:LayoutGroup>

                <dxlc:LayoutGroup View="Group" Orientation="Vertical" >
                    <dxlc:LayoutItem Label="Default Color" HorizontalAlignment="Right">
                        <dxe:PopupColorEdit 
                                        IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                                        Color="{Binding DefaultColor, Mode=TwoWay}"
                                        DisplayMode="Color">
                        </dxe:PopupColorEdit>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Created Color" HorizontalAlignment="Right">
                        <dxe:PopupColorEdit 
                                        IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                                        Color="{Binding CreatedColor, Mode=TwoWay}"
                                        DisplayMode="Color">
                        </dxe:PopupColorEdit>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Written Color" HorizontalAlignment="Right">
                        <dxe:PopupColorEdit 
                                        IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                                        Color="{Binding WrittenColor, Mode=TwoWay}" 
                                        DisplayMode="Color">
                        </dxe:PopupColorEdit>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Accessed Color" HorizontalAlignment="Right">
                        <dxe:PopupColorEdit
                                        IsEnabled="{Binding IsEnabled, ElementName=ceColorCodeDates}"
                                        Color="{Binding AccessedColor, Mode=TwoWay}" 
                                        DisplayMode="Color">
                        </dxe:PopupColorEdit>
                    </dxlc:LayoutItem>
                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>

            <dxlc:LayoutGroup Header="SharePoint Information"
                View="GroupBox" Orientation="Vertical" 
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                IsCollapsible="True"  IsCollapsed="False">

                <dxlc:LayoutGroup View="Group" Orientation="Horizontal" >
                    
                    <dxlc:LayoutItem HorizontalAlignment="Left">
                        <dxe:CheckEdit x:Name="ceIllegalCharacters"
                            Content="Check for Illegal Characters" 
                            IsChecked="False"/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Illegal Characters Color" HorizontalAlignment="Right">
                        <dxe:PopupColorEdit HorizontalAlignment="Right" Width="100"
                                        IsEnabled="{Binding IsEnabled, ElementName=ceIllegalCharacters}"
                                        Color="{Binding IllegalCharacterColors, Mode=TwoWay}" >
                        </dxe:PopupColorEdit>
                    </dxlc:LayoutItem>
                    
                </dxlc:LayoutGroup>

                <dxlc:LayoutItem Label="Illegal Folder Characters" LabelHorizontalAlignment="Right" Margin="20,0,0,0">
                    <dxe:TextEdit x:Name="teIllegalFolderCharacters" 
                                Text="{Binding IllegalFolderCharacters}"
                            	ToolTip="{Binding IllegalFolderCharactersToolTip }"/>
                </dxlc:LayoutItem>

                <dxlc:LayoutItem Label="Illegal File Characters" LabelHorizontalAlignment="Right" Margin="20,0,0,0">
                    <dxe:TextEdit x:Name="teIllegalFileCharacters" 
                                Text="{Binding IllegalFileCharacters}"
                            	ToolTip="{Binding IllegalFileCharactersToolTip }"/>
                </dxlc:LayoutItem>

                <dxlc:LayoutGroup View="Group" Orientation="Horizontal" >
                    
                    <dxlc:LayoutItem HorizontalAlignment="Left">
                        <dxe:CheckEdit x:Name="ceCheckPathLength"
                            Content="Check Path Length" 
                            IsChecked="False"/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Illegal Path Length Color" HorizontalAlignment="Right">
                        <dxe:PopupColorEdit HorizontalAlignment="Right" Width="100"
                                        IsEnabled="{Binding IsEnabled, ElementName=ceCheckPathLength}"
                                        Color="{Binding IllegalPathLengthColor, Mode=TwoWay}" >
                        </dxe:PopupColorEdit>
                    </dxlc:LayoutItem>
                    
                </dxlc:LayoutGroup>

                <dxlc:LayoutItem Label="Maximum File Name Length" Margin="20,0,0,0">
                    <dxe:TextEdit x:Name="teMaxPathLength" HorizontalAlignment="Left"
                                Text="{Binding MaxPathLength}"
                            	ToolTip="{Binding MaxPathLengthToolTip }"/>
                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>

            <dxlc:LayoutGroup HorizontalAlignment="Right">

                <dxlc:LayoutItem>
                    <Button x:Name="btnCancel" 
			        Content="Cancel" 
                    ToolTip="TCancel ToolTip"
                    HorizontalAlignment="Right"
                    Foreground="Red"
                    BorderBrush="Red"
                    Click="btnCancel_Click"  />
                </dxlc:LayoutItem>

                <!--<dxlc:LayoutItem>
                    <Button x:Name="btnCreateFolderMap" 
			        Content="Create Folder Map" 
                    ToolTip="Table Info ToolTip"
                    HorizontalAlignment="Right"
                    Background="#FF85F585"
                    Click="btnCreateFolderMap_Click" />
                </dxlc:LayoutItem>-->
                
                <!-- Second form uses CommandParameter -->
                <dxlc:LayoutItem>
                    <Button 
                		Command="{Binding CreateFolderMapCommand }"
                		Content="{Binding CreateFolderMapContent, FallbackValue='CreateFolderMap' }"
                		ToolTip="{Binding CreateFolderMapToolTip, FallbackValue='CreateFolderMap ToolTip' }" />
                </dxlc:LayoutItem>
                <!-- <dxlc:LayoutItem> -->
                    <!-- <Button -->
                        <!-- Command="{Binding CreateFolderMapCommand}" -->
                        <!-- CommandParameter="{Binding CreateFolderMapCommandParameter}" -->
                        <!-- Content="{Binding CreateFolderMapContent, FallbackValue='CreateFolderMap' }" -->
                        <!-- ToolTip="{Binding CreateFolderMapToolTip, FallbackValue='CreateFolderMap ToolTip' }" /> -->
                        <!-- <Button.Background> -->
                            <!-- <ImageBrush ImageSource="\Resources\Images\VNCDeveloperMotivation.png"  /> -->
                        <!-- </Button.Background> -->
                <!-- </dxlc:LayoutItem> -->
                
            </dxlc:LayoutGroup>

        </dxlc:LayoutControl>

    </DockPanel>

</vncmvvm:ViewBase>
